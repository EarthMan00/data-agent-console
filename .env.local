NEXT_PUBLIC_AGENT_USE_REAL_API=1
# 本地控制台 -> 远程 API：必须 PROXY=0，否则请求会进本机 127.0.0.1:8000（见 next.config rewrites）。
NEXT_PUBLIC_AGENT_API_USE_PROXY=0
# 与浏览器可访问的远程 API 根一致；若直连 uvicorn 端口需带 :8000
NEXT_PUBLIC_AGENT_API_ORIGIN=http://47.111.165.122
# 多步任务 WS 走 80 反代时建议：ws://47.111.165.122（与 API 同主机）
#NEXT_PUBLIC_AGENT_WS_ORIGIN=ws://47.111.165.122
# 只有用 http://10.20.2.155:3000 这类地址打开本机 dev 时才需要；一直用 127.0.0.1 可不配。
#NEXT_DEV_ALLOWED_ORIGINS=10.20.2.155
