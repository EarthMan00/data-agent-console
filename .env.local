NEXT_PUBLIC_AGENT_USE_REAL_API=1
# 连「远程」data-agent-server 时不要开代理：代理会把请求转到本机 8000（next.config 里 AGENT_WEB_PLATFORM_INTERNAL_URL）。
# 仅当 API 在本机 8000、且希望用 /agent-platform 转发时再设 NEXT_PUBLIC_AGENT_API_USE_PROXY=1。
NEXT_PUBLIC_AGENT_API_USE_PROXY=1
NEXT_PUBLIC_AGENT_API_ORIGIN=http://47.111.165.122
# 只有用 http://10.20.2.155:3000 这类地址打开本机 dev 时才需要；一直用 127.0.0.1 可不配。
#NEXT_DEV_ALLOWED_ORIGINS=10.20.2.155
